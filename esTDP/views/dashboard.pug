doctype html
html
  head
    title Green Mobility - Dashboard
    style.
      body { font-family: 'Segoe UI', sans-serif; background-color: #e8f5e9; padding: 40px; }
      .stats-container { max-width: 800px; margin: 0 auto; background: white; padding: 30px; border-radius: 15px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }
      h1 { color: #2e7d32; border-bottom: 2px solid #a5d6a7; padding-bottom: 10px; }
      .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 30px; }
      .stat-card { background: #f1f8e9; padding: 20px; border-radius: 10px; text-align: center; border: 1px solid #c8e6c9; }
      .stat-value { font-size: 2em; font-weight: bold; color: #1b5e20; display: block; }
      .stat-label { color: #666; font-size: 0.9em; text-transform: uppercase; }
      .btn { display: inline-block; margin-top: 30px; padding: 10px 20px; background: #2e7d32; color: white; text-decoration: none; border-radius: 5px; }
  body
    .stats-container
      h1 📊 Analisi Green Mobility
      
      .grid
        .stat-card
          span.stat-label Distribuzione Urbana
          span.stat-value #{percUrbana}%
        
        .stat-card
          span.stat-label Distribuzione Extra-Urbana
          span.stat-value #{percExtra}%
          
        .stat-card(style="grid-column: span 2")
          span.stat-label Piano più richiesto
          span.stat-value #{piuPopolare}
      
      hr(style="margin-top: 40px; border: 0; border-top: 1px solid #eee;")
      a.btn(href="/") + Nuovo Abbonamento